// Water Leakage Sensor
#include "waterLeakageSensor.h"


// *******************************************************
// Inside the main.c file
// with sysClock setup
// *******************************************************

int main(void)
{

	// Base Setup
	HAL_Init();
	SystemClock_Config();

	// GPIO Setup
	waterLeakageTEST_GPIO_Init();


  // LED set up
	initialLED_TEST_WLS(0);

  while (1)
  {
	  WaterRecognizeTEST();

  }
}
